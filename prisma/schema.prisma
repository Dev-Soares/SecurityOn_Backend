// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  posts    Post[]
  complaints Complaint[]
  articles  Article[]
}

model Post {
  id        String   @id @default(uuid())
  content   String
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId  String
  imgUrl   String?
  createdAt DateTime @default(now())
}

model Complaint {
  id          String   @id @default(uuid())
  title       String
  content     String
  danger      String   @default("aviso")
  store       String?
  link        String?
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  createdAt   DateTime @default(now())
}

model Article {
  id          String   @id @default(uuid())
  bgUrl       String?
  title       String
  content     String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  createdAt   DateTime @default(now())
}
